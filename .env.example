# Environment Configuration for Notification Agent MCP Server
# Copy this file to 'env' and update with your values

# Database Configuration
CLOUD_DOG__NOTIFY__DB__URI=sqlite3://./database/notify.db

# Default Channel (REQUIRED)
CLOUD_DOG__NOTIFY__DEFAULT_CHANNEL=email

# API Server
CLOUD_DOG__NOTIFY__API_SERVER__PORT=8083
CLOUD_DOG__NOTIFY__API_SERVER__HOST=0.0.0.0
CLOUD_DOG__NOTIFY__API_SERVER__API_KEY=<API_KEY>

# Web UI Server
CLOUD_DOG__NOTIFY__WEB_SERVER__PORT=8080
CLOUD_DOG__NOTIFY__WEB_SERVER__HOST=0.0.0.0
CLOUD_DOG__NOTIFY__WEB_SERVER__USERNAME=<WEB_USERNAME>
CLOUD_DOG__NOTIFY__WEB_SERVER__PASSWORD=<WEB_PASSWORD>

# MCP Server
CLOUD_DOG__NOTIFY__MCP_SERVER__PORT=8081
CLOUD_DOG__NOTIFY__MCP_SERVER__HOST=0.0.0.0

# A2A Server
CLOUD_DOG__NOTIFY__A2A_SERVER__PORT=8082
CLOUD_DOG__NOTIFY__A2A_SERVER__HOST=0.0.0.0

# Queue Configuration
CLOUD_DOG__NOTIFY__QUEUE__DEFAULT_TTL_HOURS=24
CLOUD_DOG__NOTIFY__QUEUE__MAX_RETRIES=5

# Rate Limiting
CLOUD_DOG__NOTIFY__RATE_LIMIT__PER_CHANNEL_PER_MINUTE=600

# Circuit Breaker
CLOUD_DOG__NOTIFY__CIRCUIT__HARD_ERROR_THRESHOLD=10

# LLM Configuration (for future formatting features)
CLOUD_DOG__NOTIFY__LLM__BASE_URL=<LLM_BASE_URL>
CLOUD_DOG__NOTIFY__LLM__MODEL=<LLM_MODEL>

# Logging
CLOUD_DOG__NOTIFY__LOG__LEVEL=INFO
CLOUD_DOG__NOTIFY__LOG__FORMAT=standard
CLOUD_DOG__NOTIFY__LOG__CONSOLE=true
