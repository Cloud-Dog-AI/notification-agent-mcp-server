############################################################
# Notification Agent MCP Server - Docker Env Example
# Copy to: private/env-docker-local-smoke
# Mount into container at: /app/env (read-only)
# License: Apache-2.0 (C) Cloud-Dog, Viewdeck Engineering Ltd.
############################################################

# Core API configuration
CLOUD_DOG__NOTIFY__API_SERVER__HOST=0.0.0.0
CLOUD_DOG__NOTIFY__API_SERVER__PORT=8004
CLOUD_DOG__NOTIFY__API_SERVER__BASE_URL=http://localhost:8004
CLOUD_DOG__NOTIFY__API_SERVER__API_KEY=<SET_API_KEY>
CLOUD_DOG__NOTIFY__WEBHOOK__SECRET=<SET_WEBHOOK_SECRET>

# Default channel (must exist in DB)
CLOUD_DOG__NOTIFY__DEFAULT_CHANNEL=<SET_DEFAULT_CHANNEL_NAME>

# Message center links (used by loopback/test channels)
CLOUD_DOG__NOTIFY__MESSAGES__BASE_URL=http://localhost:8004/messages

# Web UI configuration
CLOUD_DOG__NOTIFY__WEB_SERVER__HOST=0.0.0.0
CLOUD_DOG__NOTIFY__WEB_SERVER__PORT=8005
CLOUD_DOG__NOTIFY__WEB_SERVER__BASE_URL=http://localhost:8005
CLOUD_DOG__NOTIFY__WEB_SERVER__API_BASE_URL=http://localhost:8004
CLOUD_DOG__NOTIFY__WEB_SERVER__USERNAME=<SET_WEB_USERNAME>
CLOUD_DOG__NOTIFY__WEB_SERVER__PASSWORD=<SET_WEB_PASSWORD>
CLOUD_DOG__NOTIFY__WEB_SERVER__SESSION_MAX_AGE=3600
CLOUD_DOG__NOTIFY__AUTH__JWT_SECRET=<SET_JWT_SECRET>

# MCP server configuration
CLOUD_DOG__NOTIFY__MCP_SERVER__HOST=0.0.0.0
CLOUD_DOG__NOTIFY__MCP_SERVER__PORT=8006
CLOUD_DOG__NOTIFY__MCP_SERVER__BASE_URL=http://localhost:8006
CLOUD_DOG__NOTIFY__MCP_SERVER__API_BASE_URL=http://localhost:8004
CLOUD_DOG__NOTIFY__MCP_SERVER__API_KEY=<SET_API_KEY>
CLOUD_DOG__NOTIFY__MCP_SERVER__TRANSPORT=streamable_http
CLOUD_DOG__NOTIFY__MCP_SERVER__PROTOCOL_VERSION=2025-11-25
CLOUD_DOG__NOTIFY__MCP_SERVER__CLIENT_API_KEY=
CLOUD_DOG__NOTIFY__MCP_SERVER__SESSION_TTL_SECONDS=3600
CLOUD_DOG__NOTIFY__MCP_SERVER__STREAMABLE_HTTP_PATH=/mcp
CLOUD_DOG__NOTIFY__MCP_SERVER__JSONRPC_PATH=/messages
CLOUD_DOG__NOTIFY__MCP_SERVER__LEGACY_SSE_PATH=/sse
CLOUD_DOG__NOTIFY__MCP_SERVER__LEGACY_SSE_MESSAGE_PATH=/message
CLOUD_DOG__NOTIFY__MCP_SERVER__ASYNC_JOBS_ENABLED=false
CLOUD_DOG__NOTIFY__MCP_SERVER__ASYNC_JOBS_STATUS_PATH=/jobs/{job_id}
CLOUD_DOG__NOTIFY__MCP_SERVER__ASYNC_JOBS_TIMEOUT_SECONDS=900
CLOUD_DOG__NOTIFY__MCP_SERVER__ASYNC_JOBS_POLL_INTERVAL_SECONDS=2

# MCP server TLS (optional)
CLOUD_DOG__NOTIFY__MCP_SERVER__TLS=false
CLOUD_DOG__NOTIFY__APP__CERTIFICATE=/app/certs/server.crt
CLOUD_DOG__NOTIFY__APP__KEY=/app/certs/server.key

# A2A server configuration
CLOUD_DOG__NOTIFY__A2A_SERVER__HOST=0.0.0.0
CLOUD_DOG__NOTIFY__A2A_SERVER__PORT=8007
CLOUD_DOG__NOTIFY__A2A_SERVER__BASE_URL=http://localhost:8007

# Database configuration (MariaDB recommended for Docker)
# Example: mysql+pymysql://notify:<PASSWORD>@mariadb:3306/notification_server
CLOUD_DOG__NOTIFY__DB__URI=mysql+pymysql://notify:<DB_PASSWORD>@mariadb:3306/notification_server

# If using host networking (local MariaDB on the host), use:
# CLOUD_DOG__NOTIFY__DB__URI=mysql+pymysql://notify:<DB_PASSWORD>@localhost:3306/notification_server

# LLM configuration (Ollama on llm2)
CLOUD_DOG__NOTIFY__LLM__PROVIDER=ollama
CLOUD_DOG__NOTIFY__LLM__BASE_URL=http://llm2:11434
CLOUD_DOG__NOTIFY__LLM__MODEL=qwen3:14b
CLOUD_DOG__NOTIFY__LLM__TEMPERATURE=0.1
CLOUD_DOG__NOTIFY__LLM__MAX_TOKENS=32768
CLOUD_DOG__NOTIFY__LLM__NUM_CTX=32768
CLOUD_DOG__NOTIFY__LLM__NUM_PREDICT=32768
CLOUD_DOG__NOTIFY__LLM__QUERY_TIMEOUT=900
CLOUD_DOG__NOTIFY__LLM__TRANSLATION_TIMEOUT=900
CLOUD_DOG__NOTIFY__LLM__FORMATTING_TIMEOUT=600
CLOUD_DOG__NOTIFY__LLM__SUMMARIZATION_TIMEOUT=600

# If using host networking (local Ollama), use:
# CLOUD_DOG__NOTIFY__LLM__BASE_URL=http://localhost:11434

# TLS trust (optional CA bundle for outbound HTTPS)
# SSL_CERT_FILE and REQUESTS_CA_BUNDLE are honoured by most HTTP clients
SSL_CERT_FILE=/app/certs/ca.crt
REQUESTS_CA_BUNDLE=/app/certs/ca.crt

# Storage configuration (external volume recommended)
CLOUD_DOG__NOTIFY__STORAGE__BACKEND=local
CLOUD_DOG__NOTIFY__STORAGE__LOCAL__BASE_PATH=/app/storage
CLOUD_DOG__NOTIFY__STORAGE__LOCAL__BASE_URL=http://localhost:8004/storage

# Test configuration (smoke test destinations)
CLOUD_DOG__NOTIFY__TEST__EMAIL=<SET_TEST_EMAIL>
CLOUD_DOG__NOTIFY__TEST__MESSAGE_FILE=test/Examples/Test-Large-Text.md
CLOUD_DOG__NOTIFY__TEST__LLM_PROMPT_FILE=test/system/ST1.18_LLMFunctionality/test_prompt.txt
CLOUD_DOG__NOTIFY__TEST__LLM_CONTENT_FILE=test/system/ST1.18_LLMFunctionality/test_content.txt
CLOUD_DOG__NOTIFY__TEST__MCP_DOCKER_ENV_LOADED=true

# Slack (chat_rest) smoke test
CLOUD_DOG__NOTIFY__TEST__SLACK__BOT_TOKEN=<SET_SLACK_BOT_TOKEN>
CLOUD_DOG__NOTIFY__TEST__SLACK__CHANNEL_ID=<SET_SLACK_CHANNEL_ID>
CLOUD_DOG__NOTIFY__TEST__SLACK_CHANNEL_NAME=<SET_SLACK_CHANNEL_NAME>
CLOUD_DOG__NOTIFY__TEST__SLACK_MAX_LENGTH=400

# Webhook (chat adapter) tests
CLOUD_DOG__NOTIFY__TEST__WEBHOOK__SLACK_URL=<SET_SLACK_WEBHOOK_URL>
CLOUD_DOG__NOTIFY__TEST__WEBHOOK__DISCORD_URL=<SET_DISCORD_WEBHOOK_URL>
CLOUD_DOG__NOTIFY__TEST__WEBHOOK__INVALID_URL=not-a-url
CLOUD_DOG__NOTIFY__TEST__WEBHOOK__INVALID_SCHEME_URL=ftp://example.com
CLOUD_DOG__NOTIFY__TEST__WEBHOOK__BEARER_TOKEN=<SET_WEBHOOK_BEARER_TOKEN>

# Twilio SMS tests
CLOUD_DOG__NOTIFY__TEST__SMS__PROVIDER=twilio
CLOUD_DOG__NOTIFY__TEST__TWILIO__SMS__BASE_URL=https://api.twilio.com/2010-04-01/Accounts/<ACCOUNT_SID>/Messages.json
CLOUD_DOG__NOTIFY__TEST__TWILIO__SMS__ACCOUNT_SID=<SET_TWILIO_ACCOUNT_SID>
CLOUD_DOG__NOTIFY__TEST__TWILIO__SMS__AUTH_TOKEN=<SET_TWILIO_AUTH_TOKEN>
CLOUD_DOG__NOTIFY__TEST__TWILIO__SMS__FROM_NUMBER=<SET_TWILIO_SMS_FROM_NUMBER>
CLOUD_DOG__NOTIFY__TEST__TWILIO__SMS__VERIFY_SSL=true

# Twilio WhatsApp tests
CLOUD_DOG__NOTIFY__TEST__TWILIO__WHATSAPP__BASE_URL=https://api.twilio.com/2010-04-01/Accounts/<ACCOUNT_SID>/Messages.json
CLOUD_DOG__NOTIFY__TEST__TWILIO__WHATSAPP__ACCOUNT_SID=<SET_TWILIO_ACCOUNT_SID>
CLOUD_DOG__NOTIFY__TEST__TWILIO__WHATSAPP__AUTH_TOKEN=<SET_TWILIO_AUTH_TOKEN>
CLOUD_DOG__NOTIFY__TEST__TWILIO__WHATSAPP__FROM_NUMBER=whatsapp:<SET_TWILIO_WHATSAPP_FROM_NUMBER>
CLOUD_DOG__NOTIFY__TEST__TWILIO__WHATSAPP__VERIFY_SSL=true

# AT1.17 Email Validation tests
CLOUD_DOG__NOTIFY__TEST__AT117__MAX_WAIT=600
CLOUD_DOG__NOTIFY__TEST__AT117__POLL_INTERVAL=2.0
CLOUD_DOG__NOTIFY__TEST__AT117__RECIPIENT_EMAIL=<SET_TEST_EMAIL>
CLOUD_DOG__NOTIFY__TEST__AT117__SUBJECT=AT1.17 Email Validation
CLOUD_DOG__NOTIFY__TEST__AT117__PREF_LANGUAGE=de
CLOUD_DOG__NOTIFY__TEST__AT117__PREF_CONTENT_STYLE=html
CLOUD_DOG__NOTIFY__TEST__AT117__EXAMPLE_FILE=Test-Large-Text.md
CLOUD_DOG__NOTIFY__TEST__AT117__MAX_CHARS=5000
CLOUD_DOG__NOTIFY__TEST__AT117_ENV_LOADED=true

# Web UI integration timeouts (IT1.6/IT1.7)
CLOUD_DOG__NOTIFY__TEST__AT18__WEB_TIMEOUT=30
CLOUD_DOG__NOTIFY__TEST__AT18__PROXY_TIMEOUT=60
CLOUD_DOG__NOTIFY__TEST__AT18__CANCEL_TIMEOUT=120
CLOUD_DOG__NOTIFY__TEST__AT18__CANCEL_WAIT=30
CLOUD_DOG__NOTIFY__TEST__AT18__CANCEL_POLL_INTERVAL=2

# Logging
CLOUD_DOG__NOTIFY__LOG__LEVEL=INFO
CLOUD_DOG__NOTIFY__LOG__FORMAT=json
CLOUD_DOG__NOTIFY__LOG__CONSOLE=true
